{
  "name": "@kube-hive/oci-artifact",
  "version": "0.0.0",
  "description": "Build valid OCI images from a directory — pure JS, zero runtime dependencies",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "repository": "https://github.com/kube-hive/oci-artifact",
  "author": "axel7083",
  "homepage": "https://github.com/kube-hive/oci-artifact",
  "bugs": {
    "url": "https://github.com/kube-hive/oci-artifact/issues"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "oci-artifact": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --project integration",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24",
    "@types/node": "^24",
    "typescript": "~6.0.2",
    "vite": "^8.1.0",
    "vitest": "^4.1.10"
  },
  "dependencies": {}
}
